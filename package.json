{
  "name": "browser",
  "version": "0.0.3",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "build": "electron-builder --mac",
    "build:all": "electron-builder --mac --linux --win",
    "publish": "electron-builder --mac --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.browser.app",
    "productName": "Browser",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "ui/**/*",
      "sites/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "ui/**/*",
      "sites/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "notarize": true
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network"
    },
    "win": {
      "target": ["nsis"]
    },
    "publish": {
      "provider": "github",
      "owner": "General-Sentiment",
      "repo": "browser",
      "releaseType": "release"
    }
  }
}
